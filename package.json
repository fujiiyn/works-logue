{
  "name": "works-logue",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "dev:web": "cd apps/web && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
